 use the for statement in a program that prints all the numbers from
 n1 to n2, where n1 and n2 are two numbers spceified by the user. (hint: You'll
 need to prompt for the two values; then, inside the for statement, initiailize i to
 n1, and use n2 in teh loop conditionn
 */

#include <iostream>

using namespace std;

int main()
{
    int i, n1, n2;

    //Get number from the keyboard and initialize i

    std::cout << "Enter two numbers a and b (where a < b) and press ENTER: ";
    std::cin >> n1 >> n2;


    for(i = n1; i <= n2; i++)             //for i = 1 to n
    {
        std::cout << i << " ";          //print i
    }

    return 0;

}







