 Print 1 to N using a for loop
 Exercise 3.1.2 Chap 3
 Rewrite the example so that it prints all the numbers form n to 1 in
 reverse order. For example, the user enters 4, and the program prints 54321.
 (Hint: In the for loop, initialize i to n, use the condition i >= 1, and subtract 1
  from i in the incrememnt step).
 */

#include <iostream>

using namespace std;

int main()
{
    int i, n;

    //Get number from the keyboard and initialize i

    std::cout << "Enter a number and press ENTER: ";
    std::cin >> n;


    for(i = n; i >= 1; i--)             //for i = n to 1  here we are saying start at n and go down to >= 1
    {
        std::cout << i << " ";          //print i
    }

    return 0;

}


