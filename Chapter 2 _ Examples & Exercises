/*This program tests if a number is prime using the relational conditions
we have learned about such as <=, %, etc...*/

#include <iostream>
#include <cmath>

using namespace std;

int main()
{
   int n;                   //Number to test for prime-ness
   int i;                   //Loop counter
   int is_prime;            //Boolean flag
                            //Assume true for now

//get a number from the keyboard

std::cout << "Enter a number and press ENTER: ";
std::cin >> n;

//Test for prime by checking for divisibility
//by all whole numbers from 2 to sqrt(n)

i = 2;
while (i <= sqrt(n))        //while i is <= sqrt(n)
{
    if(n % i == 0)          //if i divides n,
        is_prime = false;   //n is not prime
    i++;                    //add 1 to i;

}

//print results
if (is_prime)
    std::cout << "Number is prime. " << std::endl;
else
    std::cout << "NUmber is not prime. " << std::endl;



return 0;
}


